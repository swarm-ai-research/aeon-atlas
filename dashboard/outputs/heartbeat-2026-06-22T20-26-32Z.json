{
  "root": "card-main",
  "state": {},
  "elements": {
    "card-main": {
      "type": "Card",
      "props": {
        "title": "Heartbeat"
      },
      "children": [
        "alert-stalled",
        "sep-1",
        "stack-pr",
        "sep-2",
        "badge-fleet",
        "sep-3",
        "stack-issues"
      ]
    },
    "alert-stalled": {
      "type": "Alert",
      "props": {
        "title": "🟡 STALLED",
