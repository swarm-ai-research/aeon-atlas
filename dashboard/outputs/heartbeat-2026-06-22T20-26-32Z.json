      ]
    },
    "heading-issues": {
      "type": "Heading",
      "props": {
        "text": "Open Issues",
        "level": "h3"
      },
      "children": []
    },
    "issue-001": {
      "type": "StoryLink",
      "props": {
        "title": "ISS-001: heartbeat recorder misclassification",
        "href": "#issues/ISS-001",
        "source": "Only open issue"
      },
      "children": []
    }
