      },
      "children": []
    },
    "sep-1": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      },
      "children": []
    },
    "stack-pr": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "md"
      },
      "children": [
        "heading-pr",
        "stat-changes",
        "stat-duration",
        "text-threshold",
        "text-action"
      ]
    },
    "heading-pr": {
      "type": "Heading",
      "props": {
        "text": "PR #13 — atlas",
        "level": "h3"
      },
      "children": []
    },
    "stat-changes": {
      "type": "Stat",
      "props": {
        "label": "Changes",
        "value": "32 new fork(s)"
      },
      "children": []
    },
    "stat-duration": {
      "type": "Stat",
      "props": {
        "label": "Time Open",
        "value": "~39h"
      },
      "children": []
    },
    "text-threshold": {
      "type": "Text",
      "props": {
        "text": "Crossed 24h stale threshold",
        "variant": "body"
      },
      "children": []
    },
    "text-action": {
      "type": "Text",
      "props": {
        "text": "Action: Auto-merge is off — requires manual review/merge",
        "variant": "lead"
      },
      "children": []
    },
    "sep-2": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      },
      "children": []
    },
    "badge-fleet": {
      "type": "Badge",
      "props": {
        "text": "Fleet: Green",
        "variant": "secondary"
      },
      "children": []
    },
    "sep-3": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      },
      "children": []
    },
    "stack-issues": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "md"
      },
      "children": [
        "heading-issues",
